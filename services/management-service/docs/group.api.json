{
  "openapi": "3.0.0",
  "info": {
    "title": "分组管理 API",
    "version": "1.0.0",
    "description": "分组和分组成员管理相关接口"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "分组管理",
      "description": "分组信息的增删改查操作"
    },
    {
      "name": "分组成员",
      "description": "分组成员的管理操作"
    }
  ],
  "paths": {
    "/api/v1/groups": {
      "get": {
        "summary": "查询分组列表",
        "description": "根据条件查询分组列表，支持分页",
        "tags": ["分组管理"],
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "分组类型（department/team/project/custom）",
            "schema": {
              "type": "string",
              "enum": ["department", "team", "project", "custom"]
            }
          },
          {
            "name": "parentId",
            "in": "query",
            "required": false,
            "description": "父分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "description": "搜索关键词",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "页码，从1开始",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建分组",
        "description": "创建新的分组",
        "tags": ["分组管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGroupRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/groups/{id}": {
      "get": {
        "summary": "获取分组详情",
        "description": "根据ID获取分组详细信息",
        "tags": ["分组管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新分组信息",
        "description": "更新指定分组的信息",
        "tags": ["分组管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateGroupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除分组",
        "description": "删除指定分组",
        "tags": ["分组管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Group deleted successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/groups/{id}/members": {
      "get": {
        "summary": "获取分组成员列表",
        "description": "获取指定分组的所有成员",
        "tags": ["分组成员"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "添加分组成员",
        "description": "向分组添加新成员",
        "tags": ["分组成员"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddGroupMemberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "添加成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Member added successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/groups/{id}/members/{employeeId}": {
      "delete": {
        "summary": "移除分组成员",
        "description": "从分组中移除指定成员",
        "tags": ["分组成员"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "employeeId",
            "in": "path",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "移除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Member removed successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/groups/{id}/members/{employeeId}/role": {
      "patch": {
        "summary": "更新成员角色",
        "description": "更新分组成员的角色",
        "tags": ["分组成员"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "分组ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "employeeId",
            "in": "path",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMemberRoleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Member role updated successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "分组唯一标识"
          },
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "code": {
            "type": "string",
            "description": "分组编码"
          },
          "name": {
            "type": "string",
            "description": "分组名称"
          },
          "type": {
            "type": "string",
            "enum": ["department", "team", "project", "custom"],
            "description": "分组类型"
          },
          "parentId": {
            "type": "string",
            "nullable": true,
            "description": "父分组ID"
          },
          "description": {
            "type": "string",
            "description": "分组描述"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "CreateGroupRequest": {
        "type": "object",
        "required": ["orgId", "code", "name", "type"],
        "properties": {
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "code": {
            "type": "string",
            "description": "分组编码"
          },
          "name": {
            "type": "string",
            "description": "分组名称"
          },
          "type": {
            "type": "string",
            "enum": ["department", "team", "project", "custom"],
            "description": "分组类型"
          },
          "parentId": {
            "type": "string",
            "description": "父分组ID"
          },
          "description": {
            "type": "string",
            "description": "分组描述"
          }
        }
      },
      "UpdateGroupRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "分组名称"
          },
          "description": {
            "type": "string",
            "description": "分组描述"
          }
        }
      },
      "AddGroupMemberRequest": {
        "type": "object",
        "required": ["employeeId"],
        "properties": {
          "employeeId": {
            "type": "string",
            "description": "员工ID"
          },
          "role": {
            "type": "string",
            "description": "角色（leader/member等）"
          }
        }
      },
      "UpdateMemberRoleRequest": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": {
            "type": "string",
            "description": "角色"
          }
        }
      },
      "PageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "总记录数"
              },
              "page": {
                "type": "integer",
                "description": "当前页码"
              },
              "size": {
                "type": "integer",
                "description": "每页数量"
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Group"
                }
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/Group"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "错误码"
          },
          "message": {
            "type": "string",
            "description": "错误信息"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      }
    }
  }
}
