{
  "openapi": "3.0.0",
  "info": {
    "title": "请假管理 API",
    "version": "1.0.0",
    "description": "假期申请和假期余额管理相关接口"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "请假管理",
      "description": "假期申请的增删改查操作"
    },
    {
      "name": "假期余额",
      "description": "假期余额查询和初始化操作"
    }
  ],
  "paths": {
    "/api/v1/leaves": {
      "get": {
        "summary": "查询假期列表",
        "description": "根据条件查询假期申请列表，支持分页",
        "tags": ["请假管理"],
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "employeeId",
            "in": "query",
            "required": false,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "假期类型（annual/sick/personal/other）",
            "schema": {
              "type": "string",
              "enum": ["annual", "sick", "personal", "other"]
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "开始日期（YYYY-MM-DD）",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "结束日期（YYYY-MM-DD）",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "页码，从1开始",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建假期申请",
        "description": "创建新的假期申请",
        "tags": ["请假管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLeaveRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/leaves/{id}": {
      "get": {
        "summary": "获取假期详情",
        "description": "根据ID获取假期申请详细信息",
        "tags": ["请假管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "假期申请ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新假期申请",
        "description": "更新指定假期申请的信息",
        "tags": ["请假管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "假期申请ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLeaveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除假期申请",
        "description": "删除指定假期申请",
        "tags": ["请假管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "假期申请ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Leave record deleted successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/leaves/balance": {
      "get": {
        "summary": "查询假期余额",
        "description": "查询员工的假期余额",
        "tags": ["假期余额"],
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "employeeId",
            "in": "query",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "query",
            "required": false,
            "description": "年份，默认为当前年份",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string"
                        },
                        "year": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/leaves/balance/initialize": {
      "post": {
        "summary": "初始化假期余额",
        "description": "为员工初始化指定年份的假期余额",
        "tags": ["假期余额"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitializeLeaveBalanceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "初始化成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "created"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Leave balance initialized successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LeaveRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "假期申请唯一标识"
          },
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "employeeId": {
            "type": "string",
            "description": "员工ID"
          },
          "type": {
            "type": "string",
            "enum": ["annual", "sick", "personal", "other"],
            "description": "假期类型"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "开始日期"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "结束日期"
          },
          "startTime": {
            "type": "string",
            "nullable": true,
            "description": "开始时间（HH:MM格式，用于小时级请假）"
          },
          "endTime": {
            "type": "string",
            "nullable": true,
            "description": "结束时间（HH:MM格式，用于小时级请假）"
          },
          "days": {
            "type": "number",
            "format": "float",
            "description": "请假天数"
          },
          "reason": {
            "type": "string",
            "description": "请假原因"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "CreateLeaveRequest": {
        "type": "object",
        "required": ["orgId", "employeeId", "type", "startDate", "endDate"],
        "properties": {
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "employeeId": {
            "type": "string",
            "description": "员工ID"
          },
          "type": {
            "type": "string",
            "enum": ["annual", "sick", "personal", "other"],
            "description": "假期类型"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "开始日期（YYYY-MM-DD）"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "结束日期（YYYY-MM-DD）"
          },
          "startTime": {
            "type": "string",
            "nullable": true,
            "description": "开始时间（HH:MM格式，可选）"
          },
          "endTime": {
            "type": "string",
            "nullable": true,
            "description": "结束时间（HH:MM格式，可选）"
          },
          "reason": {
            "type": "string",
            "description": "请假原因"
          }
        }
      },
      "UpdateLeaveRequest": {
        "type": "object",
        "properties": {
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "开始日期（YYYY-MM-DD）"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "结束日期（YYYY-MM-DD）"
          },
          "startTime": {
            "type": "string",
            "nullable": true,
            "description": "开始时间（HH:MM格式）"
          },
          "endTime": {
            "type": "string",
            "nullable": true,
            "description": "结束时间（HH:MM格式）"
          },
          "reason": {
            "type": "string",
            "description": "请假原因"
          }
        }
      },
      "InitializeLeaveBalanceRequest": {
        "type": "object",
        "required": ["orgId", "employeeId", "type", "year", "totalDays"],
        "properties": {
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "employeeId": {
            "type": "string",
            "description": "员工ID"
          },
          "type": {
            "type": "string",
            "enum": ["annual", "sick", "personal", "other"],
            "description": "假期类型"
          },
          "year": {
            "type": "integer",
            "description": "年份"
          },
          "totalDays": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "description": "总天数"
          }
        }
      },
      "PageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "总记录数"
              },
              "page": {
                "type": "integer",
                "description": "当前页码"
              },
              "size": {
                "type": "integer",
                "description": "每页数量"
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/LeaveRecord"
                }
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/LeaveRecord"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "错误码"
          },
          "message": {
            "type": "string",
            "description": "错误信息"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      }
    }
  }
}
