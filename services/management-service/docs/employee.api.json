{
  "openapi": "3.0.0",
  "info": {
    "title": "员工管理 API",
    "version": "1.0.0",
    "description": "员工信息管理相关接口"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "员工管理",
      "description": "员工信息的增删改查操作"
    }
  ],
  "paths": {
    "/api/v1/employees": {
      "get": {
        "summary": "查询员工列表",
        "description": "根据条件查询员工列表，支持分页",
        "tags": ["员工管理"],
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "description": "搜索关键词（姓名、工号等）",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "department",
            "in": "query",
            "required": false,
            "description": "部门ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "员工状态（active/inactive/on_leave）",
            "schema": {
              "type": "string",
              "enum": ["active", "inactive", "on_leave"]
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "页码，从1开始",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total": {
                          "type": "integer",
                          "description": "总记录数"
                        },
                        "page": {
                          "type": "integer",
                          "description": "当前页码"
                        },
                        "size": {
                          "type": "integer",
                          "description": "每页数量"
                        },
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Employee"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建员工",
        "description": "创建新员工信息",
        "tags": ["员工管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEmployeeRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "created"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Employee"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/employees/{id}": {
      "get": {
        "summary": "获取员工详情",
        "description": "根据ID获取员工详细信息",
        "tags": ["员工管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Employee"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "员工不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新员工信息",
        "description": "更新指定员工的信息",
        "tags": ["员工管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEmployeeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Employee"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "员工不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除员工",
        "description": "删除指定员工",
        "tags": ["员工管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Employee deleted successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "员工不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/employees/{id}/status": {
      "patch": {
        "summary": "更新员工状态",
        "description": "更新员工的在职状态",
        "tags": ["员工管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["active", "inactive", "on_leave"],
                    "description": "员工状态"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Employee status updated successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Employee": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "员工唯一标识"
          },
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "code": {
            "type": "string",
            "description": "员工工号"
          },
          "name": {
            "type": "string",
            "description": "员工姓名"
          },
          "phone": {
            "type": "string",
            "description": "手机号码"
          },
          "email": {
            "type": "string",
            "description": "邮箱地址"
          },
          "department": {
            "type": "string",
            "description": "部门ID"
          },
          "position": {
            "type": "string",
            "description": "职位"
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive", "on_leave"],
            "description": "员工状态"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "CreateEmployeeRequest": {
        "type": "object",
        "required": ["orgId", "code", "name"],
        "properties": {
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "code": {
            "type": "string",
            "description": "员工工号"
          },
          "name": {
            "type": "string",
            "description": "员工姓名"
          },
          "phone": {
            "type": "string",
            "description": "手机号码"
          },
          "email": {
            "type": "string",
            "description": "邮箱地址"
          },
          "department": {
            "type": "string",
            "description": "部门ID"
          },
          "position": {
            "type": "string",
            "description": "职位"
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive", "on_leave"],
            "description": "员工状态，默认为active"
          }
        }
      },
      "UpdateEmployeeRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "员工姓名"
          },
          "phone": {
            "type": "string",
            "description": "手机号码"
          },
          "email": {
            "type": "string",
            "description": "邮箱地址"
          },
          "department": {
            "type": "string",
            "description": "部门ID"
          },
          "position": {
            "type": "string",
            "description": "职位"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "错误码"
          },
          "message": {
            "type": "string",
            "description": "错误信息"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      }
    }
  }
}
