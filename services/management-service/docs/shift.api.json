{
  "openapi": "3.0.0",
  "info": {
    "title": "班次管理 API",
    "version": "1.0.0",
    "description": "班次定义和班次分配相关接口"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "班次管理",
      "description": "班次定义的增删改查操作"
    },
    {
      "name": "班次分配",
      "description": "班次分配相关操作"
    }
  ],
  "paths": {
    "/api/v1/shifts": {
      "get": {
        "summary": "查询班次列表",
        "description": "根据条件查询班次列表，支持分页",
        "tags": ["班次管理"],
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "班次类型（regular/overtime/standby）",
            "schema": {
              "type": "string",
              "enum": ["regular", "overtime", "standby"]
            }
          },
          {
            "name": "isActive",
            "in": "query",
            "required": false,
            "description": "是否启用",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "description": "搜索关键词",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "页码，从1开始",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "创建班次",
        "description": "创建新的班次定义",
        "tags": ["班次管理"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateShiftRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shifts/{id}": {
      "get": {
        "summary": "获取班次详情",
        "description": "根据ID获取班次详细信息",
        "tags": ["班次管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "班次ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新班次信息",
        "description": "更新指定班次的信息",
        "tags": ["班次管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "班次ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateShiftRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除班次",
        "description": "删除指定班次",
        "tags": ["班次管理"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "班次ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Shift deleted successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shifts/{id}/assign": {
      "post": {
        "summary": "分配班次",
        "description": "为员工分配指定日期的班次",
        "tags": ["班次分配"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "班次ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssignShiftRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "分配成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "created"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Shift assigned successfully"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/shifts/assignments": {
      "get": {
        "summary": "查询员工班次",
        "description": "查询指定员工在指定时间段的班次分配",
        "tags": ["班次分配"],
        "parameters": [
          {
            "name": "orgId",
            "in": "query",
            "required": true,
            "description": "组织ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "employeeId",
            "in": "query",
            "required": true,
            "description": "员工ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "description": "开始日期（YYYY-MM-DD）",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": true,
            "description": "结束日期（YYYY-MM-DD）",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 0
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ShiftAssignment"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Shift": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "班次唯一标识"
          },
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "code": {
            "type": "string",
            "description": "班次编码"
          },
          "name": {
            "type": "string",
            "description": "班次名称"
          },
          "type": {
            "type": "string",
            "enum": ["regular", "overtime", "standby"],
            "description": "班次类型"
          },
          "startTime": {
            "type": "string",
            "description": "开始时间（HH:MM格式）",
            "example": "09:00"
          },
          "endTime": {
            "type": "string",
            "description": "结束时间（HH:MM格式）",
            "example": "18:00"
          },
          "duration": {
            "type": "integer",
            "description": "班次时长（分钟）",
            "example": 480
          },
          "isOvernight": {
            "type": "boolean",
            "description": "是否跨天"
          },
          "color": {
            "type": "string",
            "description": "显示颜色",
            "example": "#1890ff"
          },
          "description": {
            "type": "string",
            "description": "班次描述"
          },
          "priority": {
            "type": "integer",
            "description": "优先级"
          },
          "isActive": {
            "type": "boolean",
            "description": "是否启用"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "CreateShiftRequest": {
        "type": "object",
        "required": ["orgId", "code", "name", "type", "startTime", "endTime", "duration"],
        "properties": {
          "orgId": {
            "type": "string",
            "description": "组织ID"
          },
          "code": {
            "type": "string",
            "description": "班次编码"
          },
          "name": {
            "type": "string",
            "description": "班次名称"
          },
          "type": {
            "type": "string",
            "enum": ["regular", "overtime", "standby"],
            "description": "班次类型"
          },
          "startTime": {
            "type": "string",
            "description": "开始时间（HH:MM格式）",
            "example": "09:00"
          },
          "endTime": {
            "type": "string",
            "description": "结束时间（HH:MM格式）",
            "example": "18:00"
          },
          "duration": {
            "type": "integer",
            "description": "班次时长（分钟）",
            "example": 480
          },
          "isOvernight": {
            "type": "boolean",
            "description": "是否跨天"
          },
          "color": {
            "type": "string",
            "description": "显示颜色"
          },
          "description": {
            "type": "string",
            "description": "班次描述"
          },
          "priority": {
            "type": "integer",
            "description": "优先级"
          },
          "isActive": {
            "type": "boolean",
            "description": "是否启用"
          }
        }
      },
      "UpdateShiftRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "班次名称"
          },
          "startTime": {
            "type": "string",
            "description": "开始时间（HH:MM格式）"
          },
          "endTime": {
            "type": "string",
            "description": "结束时间（HH:MM格式）"
          },
          "duration": {
            "type": "integer",
            "description": "班次时长（分钟）"
          },
          "isOvernight": {
            "type": "boolean",
            "description": "是否跨天"
          },
          "color": {
            "type": "string",
            "description": "显示颜色"
          },
          "description": {
            "type": "string",
            "description": "班次描述"
          },
          "priority": {
            "type": "integer",
            "description": "优先级"
          },
          "isActive": {
            "type": "boolean",
            "description": "是否启用"
          }
        }
      },
      "AssignShiftRequest": {
        "type": "object",
        "required": ["employeeId", "date"],
        "properties": {
          "employeeId": {
            "type": "string",
            "description": "员工ID"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "排班日期"
          }
        }
      },
      "ShiftAssignment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "分配记录ID"
          },
          "shiftId": {
            "type": "string",
            "description": "班次ID"
          },
          "shift_name": {
            "type": "string",
            "description": "班次名称"
          },
          "employeeId": {
            "type": "string",
            "description": "员工ID"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "排班日期"
          },
          "startTime": {
            "type": "string",
            "description": "开始时间"
          },
          "endTime": {
            "type": "string",
            "description": "结束时间"
          }
        }
      },
      "PageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "description": "总记录数"
              },
              "page": {
                "type": "integer",
                "description": "当前页码"
              },
              "size": {
                "type": "integer",
                "description": "每页数量"
              },
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Shift"
                }
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/Shift"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "错误码"
          },
          "message": {
            "type": "string",
            "description": "错误信息"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      }
    }
  }
}
