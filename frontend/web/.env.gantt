# 子路径部署配置（通过反向代理访问 /gantt）
NODE_ENV=production

# 应用基础路径（重要！）
VITE_BASE_PATH=/gantt/

# API 接口地址（注意：子路径部署时需要加上 /gantt 前缀）
VITE_APP_API_BASE_URL=/gantt/api/management-service/

# WebSocket 地址（注意：子路径部署时需要加上 /gantt 前缀）
VITE_WS_URL=/gantt/ws

# 默认组织ID和用户ID
VITE_DEFAULT_ORG_ID=default-org
VITE_DEFAULT_USER_ID=default-user
